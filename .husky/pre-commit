#!/bin/sh

# Pre-commit quality gate - ensures all changes pass build, lint, and tests

echo "Running pre-commit quality checks..."

echo "Building TypeScript..."
bun run build || {
    echo "Build failed! Fix TypeScript errors before committing."
    exit 1
}

echo "Running ESLint..."
bun run lint || {
    echo "Lint failed! Fix ESLint errors before committing."
    exit 1
}

echo "Running critical tests..."
bun test test/integration/real-compilation.test.ts || {
    echo "Critical tests failed! Fix failing tests before committing."
    exit 1
}

echo "All quality checks passed."
