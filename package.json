{
  "name": "@lars-artmann/typespec-asyncapi",
  "version": "0.2.0-beta",
  "private": false,
  "description": "TypeSpec emitter for AsyncAPI 3.1 specifications",
  "keywords": [
    "amqp",
    "api",
    "asyncapi",
    "asyncapi3",
    "beta",
    "code-generation",
    "emitter",
    "event-driven",
    "event-streaming",
    "kafka",
    "microservices",
    "microsoft-typespec",
    "mqtt",
    "openapi",
    "schema-generation",
    "specification",
    "typespec",
    "websockets"
  ],
  "homepage": "https://github.com/LarsArtmann/typespec-asyncapi#readme",
  "bugs": {
    "url": "https://github.com/LarsArtmann/typespec-asyncapi/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Lars Artmann",
    "url": "https://github.com/LarsArtmann"
  },
  "contributors": [
    {
      "name": "TypeSpec AsyncAPI Team",
      "url": "https://github.com/LarsArtmann/typespec-asyncapi/graphs/contributors"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LarsArtmann/typespec-asyncapi.git"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist/",
    "lib/"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "typespec": "./lib/main.tsp",
      "default": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "bun x tsc -p tsconfig.json",
    "build:watch": "bun x tsc -p tsconfig.json --watch",
    "compile": "tsp compile .",
    "clean": "trash dist .tsbuildinfo 2>/dev/null || true",
    "clean:test": "trash tsp-test tsp-output test-output @lars-artmann output 2>/dev/null || true",
    "pretest": "bun run clean:test && bun run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "bun run build && vitest run --coverage",
    "test:coverage:gate": "bun run test:coverage && bun run scripts/coverage-gate.ts",
    "test:validation": "bun run build && vitest run test/critical-validation.test.ts test/all-generated-specs-validation.test.ts",
    "test:asyncapi": "bun run build && vitest run test/validation/",
    "typecheck": "bun x tsc --noEmit",
    "lint": "eslint src && oxlint . --deny-warnings",
    "lint:eslint": "eslint src",
    "lint:ox": "oxlint . --deny-warnings",
    "lint:fix": "eslint src --fix",
    "check": "bun run typecheck && bun run lint",
    "validate": "bun run check && bun run test",
    "dev": "bun run --watch src/index.ts",
    "debug": "node --inspect-brk ./dist/index.js",
    "debug:test": "vitest run --inspect-brk",
    "audit": "bun audit",
    "audit:fix": "bun audit --fix",
    "security": "bun run audit && bun run test",
    "outdated": "bun outdated",
    "deps:update": "bun update",
    "alpha-release": "bun run clean && bun run build && bun run test && bun run lint",
    "prepublishOnly": "bun run check && bun run build && bun run test",
    "version": "bun run build && bun run test && git add .",
    "postversion": "git push && git push --tags",
    "prepare": "husky"
  },
  "dependencies": {
    "@typespec/asset-emitter": "^0.79.1",
    "@typespec/compiler": "^1.13.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@asyncapi/parser": "^3.6.0",
    "@asyncapi/specs": "6.11.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "ajv": "^8.20.0",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "@asyncapi/specs": "6.11.1",
    "form-data": "^4.0.0",
    "tough-cookie": "^4.1.4"
  },
  "engines": {
    "node": ">=20.11"
  },
  "tspMain": "lib/main.tsp",
  "typespec": {
    "emitter": true,
    "language": "asyncapi",
    "emitter-output-dir": "tsp-output/@lars-artmann/typespec-asyncapi",
    "options": {
      "output-file": "asyncapi",
      "file-type": "yaml"
    }
  }
}
