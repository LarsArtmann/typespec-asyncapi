{
  "plugins": ["node", "oxc", "typescript", "unicorn", "vitest"],
  "categories": {
    "perf": "warn",
    "style": "warn",
    "restriction": "warn",
    "nursery": "off",
    "correctness": "error",
    "suspicious": "error",
    "pedantic": "warn"
  },
  "rules": {
    "oxc/no-async-await": "off",
    "oxc/no-optional-chaining": "off",
    "oxc/no-rest-spread-properties": "off",
    "eslint/no-ternary": "off",
    "eslint/no-undefined": "off",
    "eslint/func-style": "off",
    "eslint/id-length": "off",
    "eslint/no-magic-numbers": "off",
    "eslint/class-methods-use-this": "off",
    "eslint/no-continue": "off",
    "eslint/no-use-before-define": "off",
    "eslint/init-declarations": "off",
    "eslint/sort-keys": "off",
    "eslint/no-inner-declarations": "off",
    "eslint/no-console": "off",
    "typescript/explicit-member-accessibility": "off",
    "unicorn/no-null": "off",
    "unicorn/filename-case": "off",
    "eslint/max-statements": ["warn", { "max": 150 }],
    "eslint/max-lines-per-function": ["warn", { "max": 350 }],
    "eslint/max-params": ["warn", { "max": 5 }],
    "eslint/max-lines": ["warn", { "max": 500 }],
    "eslint/complexity": ["warn", { "max": 100 }]
  },
  "overrides": [
    {
      "files": ["test/**"],
      "rules": {
        "vitest/require-test-timeout": "off",
        "vitest/prefer-expect-assertions": "off",
        "vitest/max-expects": "off",
        "vitest/no-conditional-in-test": "off",
        "vitest/prefer-strict-boolean-matchers": "off",
        "vitest/prefer-importing-vitest-globals": "off",
        "vitest/require-hook": "off",
        "vitest/prefer-describe-function-title": "off",
        "vitest/prefer-each": "off",
        "vitest/prefer-to-be-truthy": "off",
        "typescript/no-non-null-assertion": "off",
        "typescript/no-explicit-any": "off",
        "typescript/explicit-function-return-type": "off",
        "typescript/explicit-module-boundary-types": "off",
        "typescript/no-inferrable-types": "off",
        "typescript/no-var-requires": "off",
        "typescript/no-require-imports": "off",
        "typescript/consistent-type-imports": "off",
        "eslint/require-unicode-regexp": "off",
        "eslint/no-console": "off",
        "eslint/sort-imports": "off",
        "eslint/no-warning-comments": "off",
        "eslint/require-await": "off",
        "eslint/no-inline-comments": "off",
        "eslint/new-cap": "off",
        "eslint/func-names": "off",
        "eslint/prefer-named-capture-group": "off",
        "eslint/no-empty-function": "off",
        "eslint/prefer-arrow-callback": "off",
        "eslint/no-duplicate-imports": "off",
        "eslint/no-param-reassign": "off",
        "eslint/no-eq-null": "off",
        "eslint/no-await-in-loop": "off",
        "eslint/eqeqeq": "off",
        "eslint/no-plusplus": "off",
        "eslint/no-lone-blocks": "off",
        "eslint/no-empty": "off",
        "eslint/max-lines-per-function": "off",
        "eslint/max-statements": "off",
        "eslint/max-lines": "off",
        "eslint/complexity": "off",
        "eslint/init-declarations": "off",
        "node/no-sync": "off",
        "node/global-require": "off",
        "unicorn/prefer-module": "off",
        "unicorn/import-style": "off",
        "unicorn/no-lonely-if": "off",
        "unicorn/no-array-callback-reference": "off",
        "unicorn/no-array-for-each": "off",
        "unicorn/empty-brace-spaces": "off",
        "unicorn/no-nested-ternary": "off",
        "unicorn/filename-case": "off",
        "eslint/no-nested-ternary": "off",
        "eslint/sort-keys": "off"
      }
    }
  ],
  "settings": {
    "vitest": {
      "typecheck": false
    }
  },
  "env": {
    "node": true,
    "builtin": true
  }
}
